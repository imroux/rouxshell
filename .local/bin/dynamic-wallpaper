#!/bin/sh
#
# While script is running, change wallpaper from provided folder every time a workspace switches.
#

wallpaper_dir="$HOME/.local/share/backgrounds/arcane"

handle() {
  case $1 in
  workspace*)
    swww img --transition-type fade --transition-fps 30 --transition-step 250 $(ls $wallpaper_dir/* | shuf -n 1)
    ;;
  esac
}

socat -U - UNIX-CONNECT:$XDG_RUNTIME_DIR/hypr/$HYPRLAND_INSTANCE_SIGNATURE/.socket2.sock | while read -r line; do handle "$line"; done
